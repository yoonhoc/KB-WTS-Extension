{
  "manifest_version": 3,
  "name": "KB WTS Extension",
  "version": "1.0",
  "description": "A Chrome extension to display percentage tooltips on charts.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "MAIN",
      "all_frames": true
    }
  ],
  "permissions": []
}
